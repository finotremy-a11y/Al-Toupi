<div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4 mb-8">
  <div>
    <h1 class="font-display text-al-primary text-3xl font-bold mb-2">Carte du restaurant (fichier)</h1>
    <p class="text-al-text/70 text-sm">Téléversez une image ou un PDF pour remplacer l'affichage manuel des plats côté client.</p>
  </div>
</div>

<div class="al-card al-card-light shadow-al-medium max-w-3xl mx-auto">
  <%= form_with model: [:admin, @menu_card], url: admin_menu_card_path, method: :patch, class: "space-y-6" do |f| %>
    <% if @menu_card.errors.any? %>
      <div class="al-alert al-alert-error">
        <p class="font-semibold mb-2">Veuillez corriger les erreurs suivantes :</p>
        <ul class="list-disc list-inside space-y-1 text-sm">
          <% @menu_card.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="al-form-group">
      <%= f.label :title, "Titre" %>
      <%= f.text_field :title, class: "al-input", placeholder: "Ex: Carte été 2026" %>
    </div>

    <div class="al-form-group">
      <%= f.label :file, "Fichier de carte" %>
      <% if @menu_card.file.attached? %>
        <div class="mb-3 p-3 rounded-al border border-al-bg-medium bg-white text-sm text-al-text/70">
          Fichier actuel : <strong><%= @menu_card.file.filename %></strong>
        </div>
      <% end %>
      <%= f.file_field :file,
            accept: ".jpg,.jpeg,.png,.webp,.pdf,image/jpeg,image/png,image/webp,application/pdf",
        class: "al-file-input w-full text-sm text-al-text/70" %>
      <p class="mt-2 text-xs text-al-text/55">Formats autorisés: JPG, PNG, WEBP, PDF.</p>
    </div>

    <% if @menu_card.file.attached? %>
      <div class="al-divider"></div>
      <div>
        <h2 class="font-display text-al-primary text-2xl font-bold mb-3">Aperçu</h2>
        <% if @menu_card.image? %>
          <div class="rounded-al-lg overflow-hidden border border-al-bg-medium shadow-al-soft bg-white">
            <%= image_tag @menu_card.file, class: "w-full h-auto" %>
          </div>
        <% else %>
          <div class="rounded-al-lg border border-al-bg-medium bg-white p-4 text-sm text-al-text/80">
            PDF téléversé. Il sera affiché dans la page Carte avec un lien de téléchargement.
          </div>
        <% end %>
      </div>
    <% end %>

    <div class="al-divider"></div>

    <div class="flex flex-col sm:flex-row gap-3 pt-1">
      <%= f.submit "Enregistrer la carte", class: "al-btn al-btn-primary px-6 py-3" %>
      <%= link_to "Retour admin", admin_root_path, class: "al-btn al-btn-outline px-6 py-3" %>
    </div>
  <% end %>

  <% if @menu_card.persisted? && @menu_card.file.attached? %>
    <div class="mt-3">
      <%= button_to "Supprimer la carte actuelle", admin_menu_card_path,
            method: :delete,
            data: { turbo_confirm: "Supprimer la carte uploadée ? La carte manuelle sera réaffichée côté client." },
            class: "al-btn al-btn-outline px-6 py-3 text-red-700 border-red-400 hover:bg-red-50" %>
    </div>
  <% end %>
</div>
