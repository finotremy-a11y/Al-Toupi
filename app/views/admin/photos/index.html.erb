<div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4 mb-8">
  <div>
    <h1 class="font-display text-al-primary text-3xl font-bold mb-2">Galerie</h1>
    <p class="text-al-text/70 text-sm">Gérez les photos de votre galerie</p>
  </div>
  <%= link_to "➕ Ajouter une photo", new_admin_photo_path,
        class: "al-btn al-btn-primary font-semibold" %>
</div>

<div class="al-card shadow-al-medium overflow-hidden">
  <table class="al-table w-full">
    <thead>
      <tr>
        <th>Aperçu</th>
        <th>Titre</th>
        <th class="text-center">Position</th>
        <th class="text-right">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @photos.each do |photo| %>
        <tr>
          <td>
            <% if photo.image.attached? %>
              <div class="w-12 h-12 rounded-al overflow-hidden">
                <%= image_tag photo.image, class: "w-full h-full object-cover" %>
              </div>
            <% else %>
              <span class="text-al-text/50 italic text-sm">Pas d'image</span>
            <% end %>
          </td>
          <td class="font-medium text-al-primary"><%= photo.title.presence || "—" %></td>
          <td class="text-center">
            <span class="al-badge al-badge-light">
              <%= photo.position %>
            </span>
          </td>
          <td class="text-right space-x-2">
            <%= link_to "✏️ Modifier", edit_admin_photo_path(photo), class: "al-btn al-btn-sm al-btn-outline" %>
            <%= button_to "🗑️ Supprimer", admin_photo_path(photo), method: :delete,
                  data: { turbo_confirm: "Supprimer cette photo ?" },
                  class: "al-btn al-btn-sm text-red-600 hover:text-red-700 bg-transparent border-0 cursor-pointer text-sm font-semibold" %>
          </td>
        </tr>
      <% end %>
      <% if @photos.empty? %>
        <tr>
          <td colspan="4" class="text-center py-12 text-al-text/50">
            Aucune photo enregistrée. 
            <%= link_to "Ajouter la première →", new_admin_photo_path, class: "text-al-primary font-semibold hover:underline" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
