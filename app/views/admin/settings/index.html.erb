  <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4 mb-8">
    <div>
      <h1 class="font-display text-al-primary text-3xl font-bold mb-2">Paramètres du site</h1>
      <p class="text-al-text/70 text-sm">Configuration et informations importantes</p>
    </div>
    <%= link_to "➕ Ajouter un paramètre", new_admin_setting_path,
          class: "al-btn al-btn-primary font-semibold" %>
  </div>

  <% legal_settings = [
    { key: "legal_company_name", label: "Raison sociale" },
    { key: "legal_director", label: "Directeur de publication" },
    { key: "legal_host_name", label: "Nom de l'hébergeur" },
    { key: "legal_host_address", label: "Adresse de l'hébergeur" },
    { key: "legal_host_phone", label: "Téléphone de l'hébergeur" }
  ] %>
  <% settings_by_key = @settings.index_by(&:key) %>

  <div class="al-card al-card-light mb-6">
    <h2 class="font-display text-al-primary text-2xl font-bold mb-2">Informations légales</h2>
    <p class="text-sm text-al-text/70 mb-4">
      Renseignez ces champs pour alimenter automatiquement la page Mentions légales.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      <% legal_settings.each do |item| %>
        <% existing = settings_by_key[item[:key]] %>
        <div class="border border-al-text/10 rounded-xl p-4 bg-white/70">
          <p class="font-semibold text-al-text"><%= item[:label] %></p>
          <p class="font-mono text-xs text-al-text/55 mt-1"><%= item[:key] %></p>
          <div class="mt-3">
            <% if existing.present? %>
              <%= link_to "Modifier", edit_admin_setting_path(existing), class: "al-btn al-btn-sm al-btn-outline" %>
            <% else %>
              <%= link_to "Créer", new_admin_setting_path(key: item[:key]), class: "al-btn al-btn-sm al-btn-primary" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="al-card shadow-al-medium overflow-x-auto">
    <table class="al-table w-full">
      <thead>
        <tr>
          <th class="w-1/3">Clé</th>
          <th>Valeur</th>
          <th class="text-right">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @settings.each do |setting| %>
          <tr>
            <td class="font-mono text-xs text-al-secondary font-bold">
              <%= setting.key %>
            </td>
            <td class="text-al-text/70">
              <% if setting.value.present? %>
                <span class="line-clamp-2"><%= setting.value %></span>
              <% else %>
                <span class="text-al-text/40 italic">vide</span>
              <% end %>
            </td>
            <td class="text-right space-x-2">
              <%= link_to "✏️ Modifier", edit_admin_setting_path(setting), class: "al-btn al-btn-sm al-btn-outline" %>
              <%= button_to "🗑️ Supprimer", admin_setting_path(setting), method: :delete,
                    data: { turbo_confirm: "Supprimer ce paramètre ?" },
                    class: "al-btn al-btn-sm text-red-600 hover:text-red-700 bg-transparent border-0 cursor-pointer text-sm font-semibold" %>
            </td>
          </tr>
        <% end %>
        <% if @settings.empty? %>
          <tr>
            <td colspan="3" class="text-center py-12 text-al-text/50">
              Aucun paramètre enregistré.
              <%= link_to "Ajouter le premier →", new_admin_setting_path, class: "text-al-primary font-semibold hover:underline" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
