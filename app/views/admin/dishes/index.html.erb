  <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4 mb-8">
    <div>
      <h1 class="font-display text-al-primary text-3xl font-bold mb-2">Visuels de la carte</h1>
      <p class="text-al-text/70 text-sm">Ajoutez une photo par entrée de catégorie</p>
    </div>
    <%= link_to "➕ Ajouter un plat", new_admin_dish_path,
          class: "al-btn al-btn-primary font-semibold" %>
  </div>

  <div class="al-card shadow-al-medium overflow-x-auto">
    <table class="al-table w-full">
      <thead>
        <tr>
          <th>Photo</th>
          <th>Catégorie</th>
          <th class="text-center">Pos.</th>
          <th class="text-right">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @dishes.each do |dish| %>
          <tr>
            <td>
              <% if dish.photo.attached? %>
                <div class="w-20 h-16 rounded-al overflow-hidden">
                  <%= image_tag dish.photo, class: "w-full h-full object-cover" %>
                </div>
              <% else %>
                <span class="text-al-text/50 text-sm">—</span>
              <% end %>
            </td>
            <td class="text-al-text/70">
              <span class="al-badge al-badge-light">
                <%= dish.dish_category.name %>
              </span>
            </td>
            <td class="text-center">
              <span class="al-badge al-badge-light">
                <%= dish.position %>
              </span>
            </td>
            <td class="text-right space-x-2">
              <%= link_to "✏️ Modifier", edit_admin_dish_path(dish), class: "al-btn al-btn-sm al-btn-outline" %>
              <%= button_to "🗑️ Supprimer", admin_dish_path(dish), method: :delete,
                    data: { turbo_confirm: "Supprimer ce plat ?" },
                    class: "al-btn al-btn-sm text-red-600 hover:text-red-700 bg-transparent border-0 cursor-pointer text-sm font-semibold" %>
            </td>
          </tr>
        <% end %>
        <% if @dishes.empty? %>
          <tr>
            <td colspan="4" class="text-center py-12 text-al-text/50">
              Aucun plat enregistré.
              <%= link_to "Ajouter le premier →", new_admin_dish_path, class: "text-al-primary font-semibold hover:underline" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
