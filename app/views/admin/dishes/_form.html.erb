<div class="al-card al-card-light shadow-al-medium max-w-3xl mx-auto">
  <%= form_with model: [:admin, dish], class: "space-y-6" do |f| %>
    <% if dish.errors.any? %>
      <div class="al-alert al-alert-error">
        <p class="font-semibold mb-2">Veuillez corriger les erreurs suivantes :</p>
        <ul class="list-disc list-inside space-y-1 text-sm">
          <% dish.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="al-form-group">
      <%= f.label :dish_category_id, "Catégorie" %>
      <%= f.select :dish_category_id,
            options_from_collection_for_select(dish_categories, :id, :name, dish.dish_category_id),
            { prompt: "Choisir une catégorie" },
            class: "al-select" %>
    </div>

    <div class="al-form-group mb-0">
      <%= f.label :position, "Position" %>
      <%= f.number_field :position, class: "al-input", placeholder: "1" %>
    </div>

    <div class="al-form-group">
      <%= f.label :photo, "Photo du plat" %>
      <% if dish.persisted? && dish.photo.attached? %>
        <div class="mb-3 rounded-al overflow-hidden border-2 border-al-bg-medium shadow-al-soft">
          <%= image_tag dish.photo, class: "h-40 w-full object-cover" %>
        </div>
      <% end %>
      <%= f.file_field :photo, required: dish.new_record?, accept: "image/*", class: "w-full text-sm text-al-text/70 file:mr-4 file:py-2 file:px-4 file:rounded-al file:border-0 file:bg-al-bg-light file:text-al-primary file:font-semibold hover:file:bg-al-bg-medium" %>
      <p class="mt-2 text-sm text-al-text/65">Un seul visuel est requis. Aucun texte ni prix n'est demandé.</p>
    </div>

    <div class="al-divider"></div>

    <div class="flex flex-col sm:flex-row gap-3 pt-1">
      <%= f.submit dish.persisted? ? "Enregistrer" : "Ajouter",
            class: "al-btn al-btn-primary px-6 py-3" %>
      <%= link_to "Annuler", admin_dishes_path, class: "al-btn al-btn-outline px-6 py-3" %>
    </div>
  <% end %>
</div>
