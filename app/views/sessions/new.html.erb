<%= content_tag :div, class: "min-h-screen flex items-center justify-center bg-stone-100" do %>
  <div class="bg-white shadow rounded-lg p-8 w-full max-w-sm">
    <h1 class="text-2xl font-bold text-amber-700 mb-6 text-center">Al Toupi — Connexion</h1>

    <% if alert.present? %>
      <div class="bg-red-100 border border-red-300 text-red-700 px-4 py-2 rounded text-sm mb-4">
        <%= alert %>
      </div>
    <% end %>

    <%= form_with url: login_path, method: :post do |f| %>
      <div class="mb-4">
        <%= f.label :email, "Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email, required: true, autofocus: true,
              class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
      </div>

      <div class="mb-6">
        <%= f.label :password, "Mot de passe", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password, required: true,
              class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
      </div>

      <%= f.submit "Se connecter",
            class: "w-full bg-amber-700 text-white font-semibold py-2 rounded hover:bg-amber-800 transition-colors cursor-pointer" %>
    <% end %>
  </div>
<% end %>
