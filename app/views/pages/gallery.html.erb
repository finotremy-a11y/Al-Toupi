<%# == Galerie photos == %>
<section class="al-section-lg">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16 al-fade-in">
      <h1 class="font-display text-al-primary text-5xl md:text-6xl font-bold mb-4">Galerie</h1>
      <div class="w-24 h-1 bg-gradient-to-r from-al-primary to-al-secondary mx-auto rounded-full mb-6"></div>
      <div class="flex flex-col items-center text-center">
        <p class="w-full max-w-2xl text-al-text text-lg font-light">
          Découvrez les plus beaux moments de nos services et l'ambiance chaleureuse de notre restaurant
        </p>
      </div>
    </div>

    <% if @photos.empty? %>
      <p class="text-center text-al-text/50 py-12 text-lg">La galerie sera bientôt enrichie de nouvelles photos.</p>
    <% else %>
      <!-- Masonry Grid Layout -->
      <div class="columns-1 md:columns-2 lg:columns-3 gap-8 space-y-8">
        <% @photos.each_with_index do |photo, idx| %>
          <% if photo.image.attached? %>
            <div class="break-inside-avoid group al-card al-card-accent-surface overflow-hidden shadow-al-soft hover:shadow-al-medium transition-all duration-300 al-fade-in" style="animation-delay: #{idx * 0.05}s">
              <div class="relative overflow-hidden rounded-al-lg">
                <%= image_tag photo.image,
                      class: "w-full h-auto object-cover transition-transform duration-500 group-hover:scale-105",
                      alt: photo.title.presence || "Photo Al Toupi" %>
                <% if photo.title.present? %>
                  <div class="absolute inset-0 bg-gradient-to-t from-al-primary/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
                    <p class="text-white font-semibold text-lg"><%= photo.title %></p>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
</section>
