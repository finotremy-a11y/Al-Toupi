<%# == La Carte == %>
<section class="al-section-lg">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-12 al-fade-in">
      <h1 class="font-display text-al-primary text-5xl md:text-6xl font-bold mb-4">Notre Carte</h1>
      <div class="w-24 h-1 bg-gradient-to-r from-al-primary to-al-secondary mx-auto rounded-full mb-6"></div>
    </div>

    <% menu_intro = setting_value("menu_intro") %>
    <% if menu_intro.present? %>
      <div class="mb-12 flex flex-col items-center text-center">
        <p class="w-full max-w-2xl text-al-text text-lg font-light leading-relaxed">
          <%= menu_intro %>
        </p>
      </div>
    <% end %>

    <% if @menu_card&.file&.attached? %>
      <div class="al-card al-card-accent-surface shadow-al-medium">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
          <h2 class="font-display text-al-primary text-3xl font-bold"><%= @menu_card.title %></h2>
          <%= link_to "Télécharger la carte", url_for(@menu_card.file),
                class: "al-btn al-btn-primary",
                target: "_blank",
                rel: "noopener" %>
        </div>

        <% if @menu_card.image? %>
          <div class="rounded-al-lg overflow-hidden bg-white">
            <%= image_tag @menu_card.file,
                  class: "w-full h-auto",
                  alt: @menu_card.title %>
          </div>
        <% else %>
          <div class="rounded-al-lg overflow-hidden bg-white" style="min-height: 60vh;">
            <iframe
              src="<%= url_for(@menu_card.file) %>"
              class="w-full h-[70vh] min-h-[28rem] border-0"
              title="<%= @menu_card.title %>">
            </iframe>
          </div>
        <% end %>
      </div>
    <% else %>
      <% if @categories.empty? %>
        <p class="text-center text-al-text/50 py-12">La carte n'est pas encore disponible.</p>
      <% end %>

      <% @categories.each_with_index do |category, cat_index| %>
        <div class="mb-16 al-fade-in" style="animation-delay: #{cat_index * 0.1}s">
          <h2 class="font-display text-al-primary text-4xl font-bold border-b-2 border-al-secondary pb-4 mb-8">
            <%= category.name %>
          </h2>

          <% photo_dishes = category.dishes.ordered.select { |dish| dish.photo.attached? } %>
          <% if photo_dishes.any? %>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <% photo_dishes.each_with_index do |dish, idx| %>
                <div class="al-card hover:shadow-al-strong transition-all duration-300 al-slide-in" style="animation-delay: #{(cat_index * 0.1) + (idx * 0.05)}s">
                  <div class="overflow-hidden rounded-al-lg">
                    <%= image_tag dish.photo,
                          class: "w-full h-64 object-cover transition-transform duration-500 hover:scale-105",
                          alt: "Carte #{category.name}" %>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-al-text/60 italic">Aucune photo disponible dans cette catégorie pour le moment.</p>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
</section>
