<!DOCTYPE html>
<html lang="fr">
  <head>
    <title>Al Toupi - Restaurant à Salles-Curan</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Al Toupi">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :tailwind, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="al-public-site bg-al-bg text-al-text">

    <%# == Navigation == %>
    <header class="al-header" data-controller="mobile-nav" data-action="keydown.esc@window->mobile-nav#closeOnEscape click@window->mobile-nav#closeOnOutsideClick">
      <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between">
        <%= link_to root_path, class: "text-3xl font-bold text-al-primary tracking-wide al-brand-script" do %>
          Al Toupi
        <% end %>

        <button
          type="button"
          class="al-hamburger-btn md:hidden"
          aria-label="Ouvrir le menu"
          aria-controls="mobile-menu"
          aria-expanded="false"
          data-mobile-nav-target="button"
          data-action="mobile-nav#toggle">
          <span class="sr-only">Menu</span>
          <span class="al-hamburger-icon" aria-hidden="true">
            <span class="al-hamburger-line al-hamburger-line--top"></span>
            <span class="al-hamburger-line al-hamburger-line--middle"></span>
            <span class="al-hamburger-line al-hamburger-line--bottom"></span>
          </span>
        </button>

        <nav class="al-nav hidden md:flex">
          <%= link_to "Accueil",  root_path,    class: "#{current_page?(root_path) ? 'active' : ''}" %>
          <%= link_to "Notre Carte", menu_path, class: "#{current_page?(menu_path) ? 'active' : ''}" %>
          <%= link_to "Nos Boissons", drinks_path, class: "#{current_page?(drinks_path) ? 'active' : ''}" %>
          <%= link_to "Galerie",  gallery_path, class: "#{current_page?(gallery_path) ? 'active' : ''}" %>
          <%= link_to "Contact",  contact_path, class: "#{current_page?(contact_path) ? 'active' : ''}" %>
        </nav>
      </div>

      <div id="mobile-menu"
           class="md:hidden hidden border-t border-al-bg-medium bg-white shadow-al-soft"
           aria-hidden="true"
           data-mobile-nav-target="panel">
        <nav class="max-w-5xl mx-auto px-4 py-3 flex flex-col gap-1" aria-label="Navigation mobile">
          <%= link_to "Accueil", root_path,
                class: "px-3 py-3 rounded-al font-semibold text-al-text hover:bg-al-bg-light #{current_page?(root_path) ? 'bg-al-bg-light text-al-primary' : ''}",
                data: { action: "mobile-nav#close" } %>
              <%= link_to "Notre Carte", menu_path,
                class: "px-3 py-3 rounded-al font-semibold text-al-text hover:bg-al-bg-light #{current_page?(menu_path) ? 'bg-al-bg-light text-al-primary' : ''}",
                data: { action: "mobile-nav#close" } %>
              <%= link_to "Nos Boissons", drinks_path,
                class: "px-3 py-3 rounded-al font-semibold text-al-text hover:bg-al-bg-light #{current_page?(drinks_path) ? 'bg-al-bg-light text-al-primary' : ''}",
                data: { action: "mobile-nav#close" } %>
          <%= link_to "Galerie", gallery_path,
                class: "px-3 py-3 rounded-al font-semibold text-al-text hover:bg-al-bg-light #{current_page?(gallery_path) ? 'bg-al-bg-light text-al-primary' : ''}",
                data: { action: "mobile-nav#close" } %>
          <%= link_to "Contact", contact_path,
                class: "px-3 py-3 rounded-al font-semibold text-al-text hover:bg-al-bg-light #{current_page?(contact_path) ? 'bg-al-bg-light text-al-primary' : ''}",
                data: { action: "mobile-nav#close" } %>
        </nav>
      </div>
    </header>

    <%# == Flash messages == %>
    <% if notice.present? %>
      <div class="al-alert al-alert-success text-center" role="alert">
        ✓ <%= notice %>
      </div>
    <% end %>
    <% if alert.present? %>
      <div class="al-alert al-alert-error text-center" role="alert">
        ✗ <%= alert %>
      </div>
    <% end %>

    <%# == Contenu principal == %>
    <main>
      <%= yield %>
    </main>

    <%# == Footer == %>
    <footer class="al-footer">
      <div class="max-w-5xl mx-auto px-4 grid grid-cols-1 md:grid-cols-3 gap-8 py-12">
        <div>
          <h3 class="al-footer-title">Al Toupi</h3>
          <% full_address = setting_value("adresse", "10 Rue de la Confrérie 12410 Salles-Curan") %>
          <% postal_line = full_address[/12410\s+Salles-Curan/i] %>
          <% street_line = postal_line.present? ? full_address.sub(postal_line, "").strip : full_address %>
          <p><%= street_line.presence || full_address %></p>
          <% if postal_line.present? %>
            <p><%= postal_line %></p>
          <% end %>
        </div>
        <div>
          <h3 class="al-footer-title">Contact</h3>
          <p>Tél : <%= setting_value("telephone", "-") %></p>
          <p>Email : <%= setting_value("email", "-") %></p>
        </div>
        <div>
          <h3 class="al-footer-title">Horaires</h3>
          <p class="whitespace-pre-line"><%= setting_value("horaires", "-") %></p>
        </div>
      </div>

      <div class="border-t border-al-secondary/30">
        <div class="max-w-5xl mx-auto px-4 py-5 flex flex-col md:flex-row items-start md:items-center justify-between gap-3">
          <p class="text-sm md:text-base text-al-secondary-dark/90">&copy; <%= Date.current.year %> Al Toupi - Restaurant traditionnel</p>
          <nav class="flex flex-wrap gap-4 text-sm md:text-base">
            <%= link_to "Mentions légales", legal_mentions_path, class: "text-al-secondary-dark hover:text-al-primary" %>
            <%= link_to "Politique de confidentialité", privacy_policy_path, class: "text-al-secondary-dark hover:text-al-primary" %>
            <%= link_to "Politique cookies", cookies_policy_path, class: "text-al-secondary-dark hover:text-al-primary" %>
          </nav>
        </div>
      </div>
    </footer>

  </body>
</html>
